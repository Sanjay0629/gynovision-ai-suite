# ────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json

*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp


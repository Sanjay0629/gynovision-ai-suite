# ────────────────────────────────────────────
# Node / Frontend (Vite + React + TypeScript)
# ────────────────────────────────────────────
node_modules/
dist/
dist-ssr/
*.local
.cache/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
bun-error.log*

# TypeScript build info
*.tsbuildinfo

# ────────────────────────────────────────────
# Python / Flask Backends
# ────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Virtual environments
.venv/
venv/
env/
ENV/
.env/

# Python packaging
*.egg
*.egg-info/
dist/
build/
wheels/
*.whl
pip-log.txt
pip_error.txt

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover

# Jupyter
.ipynb_checkpoints/
*.ipynb

# ────────────────────────────────────────────
# ML Model Artifacts (large binary files)
# ────────────────────────────────────────────
*.h5
*.hdf5
*.pt
*.pth
*.onnx
*.pb
*.tflite
*.safetensors

# Keep thresholds/config JSON that are small and tracked
!backend/**/thresholds.json
!backend/**/*_thresholds.json

# ────────────────────────────────────────────
# Environment & Secrets
# ────────────────────────────────────────────
.env
.env.local
.env.development
!.env.production
!.env.example
*.pem
*.key
secrets.json

# ────────────────────────────────────────────
